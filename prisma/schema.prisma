

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}



enum UserRole {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum DietaryType {
  VEG
  NON_VEG
  VEGAN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum MealAvailability {
  AVAILABLE
  UNAVAILABLE
}

model User {
  id           String       @id @default(uuid())
  name         String
  email        String       @unique
  passwordHash String
  phone        String?
  image        String?
  role         UserRole
  status       UserStatus   @default(ACTIVE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  provider      Provider?
  orders        Order[]
  reviews       Review[]
}

model Provider {
  id          String    @id @default(uuid())
  userId      String    @unique
  shopName    String
  address     String
  shopImage   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  meals       Meal[]
  orders      Order[]
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  meals       Meal[]
}

model Meal {
  id            String            @id @default(uuid())
  providerId    String
  categoryId    String
  name          String
  image         String
  price         Decimal           @db.Decimal(10, 2)
  dietary       DietaryType
  excerpt       String
  details       String
  isFeatured    Boolean           @default(false)
  availability  MealAvailability  @default(AVAILABLE)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  provider      Provider          @relation(fields: [providerId], references: [id], onDelete: Cascade)
  category      Category          @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  orderItems    OrderItem[]
  reviews       Review[]

  @@index([providerId])
  @@index([categoryId])
  @@index([dietary])
  @@index([availability])
}

model Order {
  id              String       @id @default(uuid())
  userId          String
  providerId      String
  status          OrderStatus  @default(PENDING)
  totalAmount     Decimal      @db.Decimal(10, 2)
  deliveryAddress String
  contactPhone    String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider        Provider     @relation(fields: [providerId], references: [id], onDelete: Restrict)
  orderItems      OrderItem[]
  reviews         Review[]

  @@index([userId])
  @@index([providerId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id               String    @id @default(uuid())
  orderId          String
  mealId           String
  mealNameSnapshot String
  quantity         Int
  price            Decimal   @db.Decimal(10, 2)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  order            Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  meal             Meal      @relation(fields: [mealId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([mealId])
}

model Review {
  id          String    @id @default(uuid())
  userId      String
  mealId      String
  orderId     String
  rating      Int
  content     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  meal        Meal      @relation(fields: [mealId], references: [id], onDelete: Cascade)
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([userId, mealId])
  @@index([mealId])
  @@index([orderId])
}